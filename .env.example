# BNI Hub Configuration Example
# Rename this file to .env and fill in the actual values

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/bni_hub

# Security
SECRET_KEY=generate-a-secure-random-string-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Configuration (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
AI_MODEL=deepseek/deepseek-chat

# Server
PORT=8000
DOMAIN=bnimahardika.qd.je
